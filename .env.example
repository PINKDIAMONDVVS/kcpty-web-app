COMPANY_NAME="Vercel Inc."
SITE_NAME="Next.js Commerce"
SHOPIFY_REVALIDATION_SECRET=""
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""
SHOPIFY_STORE_DOMAIN="[your-shopify-store-subdomain].myshopify.com"

# Resend — transactional email for /contact form submissions.
RESEND_API_KEY=""
CONTACT_FROM_EMAIL="Brand <contact@yourdomain.com>"
CONTACT_TO_EMAIL="contact@yourdomain.com"

# Sentry — leave empty to disable error tracking.
# DSN comes from your Sentry project; org/project/auth-token are only needed
# for source-map uploads during `next build` on CI.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
